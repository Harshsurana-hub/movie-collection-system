<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Movie Record</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="form-card">
        <h2>🎬 Add Movie to Library</h2>
        <p style="color: #9ca3af; font-size: 14px; margin-bottom: 25px;">Fill out the fields below to add a new movie profile.</p>
        
        <form action="/createdata" method="POST">
            <div class="form-group">
                <label>Movie Name</label>
                <input type="text" name="movieName" placeholder="e.g. Interstellar" required>
            </div>
            <div class="form-group">
                <label>Director</label>
                <input type="text" name="director" placeholder="e.g. Christopher Nolan" required>
            </div>
            <div class="form-group">
                <label>Genre</label>
                <input type="text" name="genre" placeholder="e.g. Sci-Fi / Drama" required>
            </div>
            <div class="form-group">
                <label>Release Year</label>
                <input type="number" name="releaseYear" min="1880" max="2100" placeholder="e.g. 2014" required>
            </div>
            <div class="form-group">
                <label>Rating (0.0 - 10.0)</label>
                <input type="number" step="0.1" name="rating" min="0" max="10" placeholder="e.g. 8.6" required>
            </div>
            
            <div class="action-buttons">
                <button type="submit" class="btn btn-success" style="flex: 1;">Save Entry</button>
                <a href="/getdata" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</body>
</html>